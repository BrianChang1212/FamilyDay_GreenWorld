# API host root only — frontend always requests `${VITE_API_BASE}/api/v1/...`
# (see src/api/gameFlow.ts). No trailing slash.
#
# Firebase Functions emulator (see fdgw.project.json + vite proxy):
# Use localhost here if the Vite dev server is opened as http://localhost:5173
# so getViteApiBase() does not rewrite to /fdgw-emulator-api.
# VITE_API_BASE=http://localhost:5003/rare-lattice-495009-i9/us-central1/api
#
# Local mock (npm run mock:api, default port 8787):
# VITE_API_BASE=http://localhost:8787
#
# Staging / production — replace with your deployed HTTPS API root:
# VITE_API_BASE=https://your-staging-api.example.com
VITE_API_BASE=http://localhost:8787
# Optional: pin consumed contract release for traceability.
VITE_API_CONTRACT_VERSION=contract-v0.1.0
