# --- Local emulator (Vite proxy -> Functions emulator; see source/vite.config.ts)
# Firebase project / region / emulator port: repo root fdgw.project.json (single source of truth).
# VITE_API_BASE=/fdgw-emulator-api
# Optional override of project id for Vite proxy path only:
# VITE_FGW_EMULATOR_PROJECT=your-project-id

# --- Remote Cloud Functions (after `firebase deploy --only functions:api`)
# Use your deployed HTTPS root: requests become {VITE_API_BASE}/api/v1/...
# VITE_API_BASE=https://us-central1-<firebaseProjectId>.cloudfunctions.net/api
#
# If you open the app at http://localhost:5173, set on the function (remote) env:
#   FDGW_SESSION_COOKIE_SAMESITE=none
# so the session cookie uses SameSite=None; Secure and is sent on cross-origin credentialed fetch.
