# Session cookie: production (non-emulator) uses SameSite=None; Secure so
# Firebase Hosting can call the API cross-origin with credentials.
# Emulators set FUNCTIONS_EMULATOR=true and keep Lax. Override:
# FDGW_SESSION_COOKIE_SAMESITE=none

FDGW_USE_FIRESTORE=true
GOOGLE_CLOUD_PROJECT=rare-lattice-495009-i9
# Optional override for contract traceability
FDGW_API_CONTRACT_VERSION=contract-v0.1.0
