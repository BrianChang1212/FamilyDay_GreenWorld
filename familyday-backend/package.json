{
  "name": "familyday-greenworld-functions",
  "private": true,
  "version": "0.1.0",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "serve": "firebase emulators:start --only functions",
    "serve:functions": "firebase emulators:start --only functions",
    "cloud:serve": "powershell -ExecutionPolicy Bypass -File ./scripts/cloud-firestore-dev.ps1 serve",
    "cloud:verify": "powershell -ExecutionPolicy Bypass -File ./scripts/cloud-firestore-dev.ps1 verify",
    "cloud:all": "powershell -ExecutionPolicy Bypass -File ./scripts/cloud-firestore-dev.ps1 all",
    "verify:firestore": "node ./scripts/verify-firestore-flow.mjs",
    "smoke:api": "node ./scripts/smoke-api.mjs",
    "seed:roster": "node ./scripts/seed-roster-test-rows.mjs",
    "count:checkins": "node ./scripts/count-checkins-firestore.mjs",
    "purge:firestore-app": "node ./scripts/purge-firestore-app-data.mjs",
    "shell": "firebase functions:shell",
    "deploy": "firebase deploy --only functions:api",
    "sync:hosting-dist": "node ./scripts/sync-hosting-dist.mjs",
    "build:frontend:hosting": "node ./scripts/build-frontend-for-hosting.mjs",
    "deploy:hosting": "node ./scripts/build-frontend-for-hosting.mjs && node ./scripts/sync-hosting-dist.mjs && firebase deploy --only hosting",
    "deploy:app": "node ./scripts/build-frontend-for-hosting.mjs && node ./scripts/sync-hosting-dist.mjs && firebase deploy --only hosting,functions:api,firestore",
    "lint": "echo \"No lint configured\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.3",
    "firebase-tools": "^14.4.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}
