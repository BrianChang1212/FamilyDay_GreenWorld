rules_version = '2';

// FamilyDay_GreenWorld — API-only data path: browser uses REST (Cloud Functions).
// Admin SDK used by Functions bypasses these rules. Keep client direct access closed
// unless you add Firebase Client SDK reads/writes later.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
